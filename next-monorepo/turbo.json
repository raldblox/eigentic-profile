{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "CONVEX_DEPLOY_KEY",
        "CONVEX_URL",
        "CONVEX_SITE_URL",
        "DEBUG_API_ERRORS",
        "OPENAI_API_KEY",
        "OPENAI_MODEL",
        "X402_CHAIN",
        "X402_FACILITATOR_URL",
        "X402_PAYTO_EVM",
        "X402_PRICE"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "CONVEX_URL",
        "OPENAI_API_KEY",
        "OPENAI_MODEL",
        "X402_FACILITATOR_URL",
        "X402_PRICE",
        "X402_CHAIN",
        "X402_PAYTO_EVM"
      ]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
